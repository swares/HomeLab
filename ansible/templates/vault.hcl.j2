# Ansible-managed. Single-node raft (fine for a homelab). Add TLS before exposing beyond the LAN.
ui = true
storage "raft" {
  path    = "/opt/vault/data"
  node_id = "{{ inventory_hostname }}"
}
listener "tcp" {
  address     = "0.0.0.0:8200"
  tls_disable = true   # wire TLS (cert-manager / step-ca) before trusting this off-host
}
api_addr      = "http://{{ ansible_host }}:8200"
cluster_addr  = "http://{{ ansible_host }}:8201"
disable_mlock = true
