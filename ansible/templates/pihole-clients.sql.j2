-- Ansible-managed. Lab/infra hosts that must resolve UNFILTERED (no ad-block).
-- Per Pi-hole docs: adding a client auto-links it to Default group 0 (trigger); removing
-- that link leaves the client with no group -> it receives no blocklists. Household and any
-- unlisted device stays in Default(0), which keeps the ad/tracker blocking.
{% for c in dns_unfiltered_clients %}
INSERT OR IGNORE INTO client (ip, comment) VALUES ('{{ c.ip }}', '{{ c.name }} — lab, unfiltered');
{% endfor %}
DELETE FROM client_by_group
 WHERE group_id = 0
   AND client_id IN (
     SELECT id FROM client WHERE ip IN (
       {% for c in dns_unfiltered_clients %}'{{ c.ip }}'{% if not loop.last %}, {% endif %}{% endfor %}
     )
   );
