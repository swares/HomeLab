# Managed by Ansible — BARE-DNSMASQ alternative (dns_engine=dnsmasq).
# On Pi-hole v6 the equivalent records live in pihole.toml (the playbook does that);
# this drop-in is the path for a non-Pi-hole resolver. Authoritative for the lab domain.

domain={{ lab_domain }}
local=/{{ lab_domain }}/
expand-hosts

# Kubernetes ingress wildcard: *.apps.<domain> -> ingress VIP
address=/apps.{{ lab_domain }}/{{ ingress_vip }}

# Static node records (A + auto-generated PTR for the reverse zone)
{% for name, ip in dns_records.items() %}
host-record={{ name }}.{{ lab_domain }},{{ ip }}
{% endfor %}

# Upstream forwarders for everything non-lab
no-resolv
{% for up in dns_upstream %}
server={{ up }}
{% endfor %}
