#!/bin/bash
# Vault auto-unseal on boot.
# Reads unseal keys from {{ vault_unseal_keys_file }} (root:root 0400, never committed to git).
# File format: one unseal key per line, minimum {{ vault_unseal_threshold }} lines.
#
# SECURITY NOTE: storing keys on the same host as Vault means a root compromise
# exposes both. Acceptable for a home lab; for production use cloud KMS auto-unseal.

set -euo pipefail

VAULT_ADDR="{{ vault_addr | default('http://127.0.0.1:8200') }}"
KEYS_FILE="{{ vault_unseal_keys_file }}"
THRESHOLD="{{ vault_unseal_threshold | default(3) }}"
MAX_WAIT=60   # seconds to wait for Vault to become ready

export VAULT_ADDR

# Wait for Vault to be reachable
for i in $(seq 1 $MAX_WAIT); do
  if vault status 2>/dev/null | grep -q 'Initialized.*true'; then
    break
  fi
  sleep 1
done

# Already unsealed?
if vault status 2>/dev/null | grep -q 'Sealed.*false'; then
  echo "vault-unseal: already unsealed, nothing to do"
  exit 0
fi

if [[ ! -f "$KEYS_FILE" ]]; then
  echo "vault-unseal: keys file $KEYS_FILE not found — cannot unseal" >&2
  exit 1
fi

COUNT=0
while IFS= read -r key && [[ $COUNT -lt $THRESHOLD ]]; do
  [[ -z "$key" ]] && continue
  vault operator unseal "$key" > /dev/null
  COUNT=$((COUNT + 1))
done < "$KEYS_FILE"

if vault status 2>/dev/null | grep -q 'Sealed.*false'; then
  echo "vault-unseal: unsealed successfully"
else
  echo "vault-unseal: still sealed after $COUNT keys — check threshold" >&2
  exit 1
fi
