# Pre-seeded Pi-hole v6 config (Ansible-managed). Its presence is what lets the installer
# honour --unattended on a fresh host. FTL fills every unset key with its default.
# For a full reference: install once, configure to taste, then copy the resulting
# /etc/pihole/pihole.toml back here as the template.
[dns]
  domain = "{{ lab_domain }}"
  expandHosts = true
  upstreams = [{% for u in dns_upstream %}"{{ u }}"{% if not loop.last %}, {% endif %}{% endfor %}]
  # Static node records (A + auto-generated PTR for the reverse zone)
  hosts = [{% for name, ip in dns_records.items() %}"{{ ip }} {{ name }}.{{ lab_domain }}"{% if not loop.last %}, {% endif %}{% endfor %}]

[misc]
  # Kubernetes ingress wildcard, injected as a raw dnsmasq directive (v6-native way):
  dnsmasq_lines = ["address=/apps.{{ lab_domain }}/{{ ingress_vip }}"]
  # also parse user drop-ins in /etc/dnsmasq.d/ (optional extras / bare-dnsmasq parity)
  etc_dnsmasq_d = true

[webserver.api]
  # Double-sha256 hash — generate it and store in Vault; do NOT commit plaintext.
  # Empty string = no admin auth (acceptable on a trusted LAN only).
  password = "{{ pihole_web_password_hash | default('') }}"
